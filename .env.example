# Copy this file to .env.local and fill in your real key.
# .env.local is gitignored — it never gets committed.

# Pick exactly ONE provider by setting MODEL_PROVIDER, then fill in the
# matching key block below. Default is "anthropic" if unset.
# Allowed values: anthropic | openai (also accepts "deepseek" and "openrouter"
# as aliases of "openai" since both speak the OpenAI Chat Completions format).
MODEL_PROVIDER=anthropic

# === Provider: Anthropic (api.anthropic.com) ===
# Get a key at https://console.anthropic.com/. Defaults to claude-sonnet-4-6.
ANTHROPIC_API_KEY=sk-ant-xxxxx
# ANTHROPIC_MODEL=claude-sonnet-4-6
# ANTHROPIC_BASE_URL=https://your-anthropic-compatible-proxy.example  # optional

# === Provider: DeepSeek (recommended for users in mainland China) ===
# Get a key at https://platform.deepseek.com/. RMB billing, fast in CN.
# OPENAI_API_KEY=sk-xxxxx
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_MODEL=deepseek-chat

# === Provider: OpenRouter (transparent multi-model gateway) ===
# Set MODEL_PROVIDER=openai. Get a key at https://openrouter.ai/.
# OPENAI_API_KEY=sk-or-xxxxx
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_MODEL=anthropic/claude-sonnet-4-5
